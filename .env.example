# ─── Application Configuration ─────────────────────────────────────────────
# Base URL for end-to-end browser tests (staging environment).
BASE_URL=https://staging.hospitality-platform.com

# Base URL for API-level tests.
API_BASE_URL=https://api.staging.hospitality-platform.com

# ─── Authentication ──────────────────────────────────────────────────────────
# Test user credentials used by the E2E booking flow.
# Rotate these credentials monthly and never commit real production values.
TEST_USER_EMAIL=qa.automation@hospitality-platform.com
TEST_USER_PASSWORD=Qaut0m@ti0n!Secure

# ─── API Keys ────────────────────────────────────────────────────────────────
# Internal API bearer token for authenticated API tests.
API_BEARER_TOKEN=replace-with-staging-bearer-token

# LLM API key used by the AI triage support tool (Claude / Gemini).
LLM_API_KEY=replace-with-llm-api-key
LLM_PROVIDER=gemini

# ─── Feature Flags ───────────────────────────────────────────────────────────
# Set to "true" to enable screenshot capture in non-failure runs (verbose mode).
VERBOSE_SCREENSHOTS=false
